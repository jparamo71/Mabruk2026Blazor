@page "/takeninventory"

@inject IRepository repository
@inject SweetAlertService swal
@inject NavigationManager navigationManager


<div class="container">
    <div class="row mb-3">
        <div class="col">
            <h3>Toma física</h3>
        </div>
    </div>
    <div class="row mb-3">
        <div class="col">
            <div class="input-group">
                <InputText @bind-Value="textToSearch" class="form-control" />
                <button type="button" class="btn btn-primary" @onclick="@(() => GetProduct())">Buscar</button>
            </div>
        </div>
    </div>
</div>

@if (product != null)
{
    <div class="container-fluid">
        <div class="card">
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-2">
                        <label class="form-label fw-semibold">Código</label>
                        <p>@product.Code</p>
                    </div>
                    <div class="col-10">
                        <label class="form-label fw-semibold">Producto</label>
                        <p>@product.Name</p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label fw-semibold">Código de barras</label>
                        <p>@product.BarcharCode</p>
                    </div>
                    <div class="col">
                        <label class="form-label fw-semibold">Código UPC</label>
                        <p>@product.UPCCode</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="container">
        <EditForm Model="physicalInfo" OnValidSubmit="UpdatePhysicalInformation">
            <div class="row mb-3">
                <div class="col">
                    <label class="form-label fw-semibold">Cantidad de producto</label>
                    <div class="input-group">
                        <InputNumber @bind-Value="@physicalInfo.PhysicalQuantity" class="form-control form-control-lg" />
                        <button type="button" class="btn btn-success">Verificar</button>
                    </div>

                </div>
            </div>
        </EditForm>

    </div>
}

@code {
    /*
    * Get user input code
    * Search associated product
    * if found then Get user input quantity available
    * Show fully available info of product to user into screen.
    */

    private ProductDto? product;
    private string? textToSearch;
    private ProductPhysicalDto physicalInfo = new ProductPhysicalDto();



    async Task GetProduct()
    {
        var http = await repository.Get<ProductDto>($"api/product/get?code={textToSearch}");
        if (http.Error)
        {
            await swal.FireAsync("Error", await http.GetErrorMessage(), SweetAlertIcon.Error);
        }
        else
        {
            product = http.Response!;
        }
    }


    async Task UpdatePhysicalInformation()
    {

    }

}
